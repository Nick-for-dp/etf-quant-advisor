# ETF Quant Advisor Configuration

# PostgreSQL配置（通过环境变量读取）
database:
  host: ${DB_HOST}
  port: ${DB_PORT}
  database: ${DB_NAME}
  username: ${DB_USER}
  password: ${DB_PASSWORD}

  # 连接池配置
  pool_size: 5
  max_overflow: 10
  pool_timeout: 30
  pool_recycle: 3600

# 应用配置
app:
  name: "ETF Quant Advisor"
  version: "0.1.0"
  log_level: INFO
  timezone: "Asia/Shanghai"

# 数据采集配置
data_collection:
  primary_source: "akshare"
  schedule_time: "15:30"
  history_start_date: "2022-01-01"

# 监控ETF列表
watchlist:
  - code: "510300"   # 沪深300ETF
  - code: "512000"   # 券商ETF
  - code: "513100"   # 纳指ETF

# 策略参数
strategy:
  right_side:
    ma_periods: [5, 10, 20, 60]
    macd_fast: 12
    macd_slow: 26
    macd_signal: 9
    rsi_period: 14
    max_premium: 0.03
    premium_warning: 0.05
    stop_loss: -0.08
    trailing_stop: 0.05